# Public entrypoint
VOICE_HTTP_PORT=8080

# Host-side paths mounted into Docker
VOICE_RECORDINGS_DIR=.recordings
VOICE_ARTIFACTS_DIR=.reports

# Internal Docker service URLs used by the web application
VOICE_ASR_URL=http://asr-api:8100
VOICE_DIARIZATION_URL=http://diarization-api:8100
VOICE_EMOTION_URL=http://emotion-api:8100
VOICE_CONTAINER_RECORDINGS_DIR=/data/recordings
VOICE_RABBITMQ_URL=amqp://guest:guest@rabbitmq/
VOICE_RABBITMQ_QUEUE=voice.recordings

# Qwen/vLLM OpenAI-compatible endpoint shared with the MFC portal.
VOICE_QWEN_BASE_URL=http://host.docker.internal:8000/v1
VOICE_QWEN_MODEL=qwen3.6-35b
VOICE_QWEN_REPORT_TIMEOUT_SECONDS=600
VOICE_QWEN_REPORT_MAX_TOKENS=8192
VOICE_QWEN_MODEL_ID=cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit
VOICE_QWEN_VLLM_TAG=latest
VOICE_QWEN_TENSOR_PARALLEL_SIZE=2
VOICE_QWEN_GPU_MEMORY_UTILIZATION=0.85
VOICE_QWEN_MAX_MODEL_LEN=65536
VOICE_QWEN_HF_CACHE=/opt/rag/hf-cache
QWEN_NVIDIA_VISIBLE_DEVICES=0,1

# Hugging Face token for pyannote/community models.
# Keep the real value only in .env.
HF_TOKEN=

# Model runtime
MODEL_DEVICE=cuda
ASR_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
SER_MODEL=xbgoose/hubert-large-speech-emotion-recognition-russian-dusha-finetuned
NVIDIA_VISIBLE_DEVICES=0
ASR_NVIDIA_VISIBLE_DEVICES=1
DIARIZATION_NVIDIA_VISIBLE_DEVICES=0
EMOTION_NVIDIA_VISIBLE_DEVICES=0
